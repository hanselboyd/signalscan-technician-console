<Window x:Class="SignalScan.TechnicianConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SignalScan Technician Console"
        Height="820"
        Width="1180"
        MinHeight="720"
        MinWidth="980"
        Background="#F3F6FA">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource SignalNavy}" Padding="24,18">
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="SignalScan" Foreground="White" FontSize="30" FontWeight="Bold" />
          <TextBlock Text="by 909 Signal IT - Technician Console" Foreground="#BFD7FF" FontSize="14" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
          <TextBlock Text="Read-only diagnostic mode" Foreground="#A9F59B" FontWeight="SemiBold" TextAlignment="Right" />
          <TextBlock Text="No repair, cleanup, deletion, or configuration changes" Foreground="White" FontSize="12" TextAlignment="Right" />
        </StackPanel>
      </DockPanel>
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="24">
        <Border Background="#EAF7EA" BorderBrush="#BDE8B6" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,16">
          <TextBlock TextWrapping="Wrap">
            <Run FontWeight="Bold" Text="Safety rule: " />
            <Run Text="SignalScan v1 only inspects and reports. It does not delete files, modify registry keys, disable services, change drivers, remove malware, alter firewall/Defender settings, or perform automatic repairs." />
          </TextBlock>
        </Border>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Client and Device" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <TextBlock Text="Client name" Margin="0,12,0,0" />
                <TextBox x:Name="ClientNameTextBox" />
                <TextBlock Text="Client phone or email" />
                <TextBox x:Name="ClientContactTextBox" />
                <TextBlock Text="Device label" />
                <TextBox x:Name="DeviceLabelTextBox" />
                <TextBlock Text="Recommended service package" />
                <ComboBox x:Name="RecommendedServiceComboBox">
                  <ComboBoxItem Content="SignalScan PC Health Check" IsSelected="True" />
                  <ComboBoxItem Content="SignalScan Tune-Up" />
                  <ComboBoxItem Content="SignalScan Security Review" />
                  <ComboBoxItem Content="SignalScan Business Workstation Assessment" />
                  <ComboBoxItem Content="SignalCare Monthly Maintenance Plan" />
                </ComboBox>
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16">
              <StackPanel>
                <TextBlock Text="Actions" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <TextBlock Text="All actions are read-only or report export only." Foreground="#5D6B7F" Margin="0,6,0,12" TextWrapping="Wrap" />
                <Button x:Name="RunScanButton" Content="Run Read-Only Scan" Background="{StaticResource SignalBlue}" Foreground="White" Click="RunScanButton_Click" Margin="0,0,0,10" />
                <Button x:Name="ExportReportButton" Content="Export Report Draft" Click="ExportReportButton_Click" Margin="0,0,0,10" IsEnabled="False" />
                <TextBlock x:Name="StatusMessageTextBlock" Text="Ready to scan." Foreground="#5D6B7F" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Grid.Column="2">
            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,16">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="Technician Dashboard" FontSize="22" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                  <TextBlock x:Name="ScanTimestampTextBlock" Text="No scan has been run yet." Foreground="#5D6B7F" Margin="0,6,0,0" />
                </StackPanel>
                <Border Grid.Column="1" Background="#F8FBFF" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="12">
                  <StackPanel>
                    <TextBlock Text="Overall Status" Foreground="#5D6B7F" />
                    <TextBlock x:Name="OverallStatusTextBlock" Text="Review Required" FontSize="22" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                  </StackPanel>
                </Border>
              </Grid>
            </Border>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                  <TextBlock Text="System Summary" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                  <TextBlock x:Name="SystemSummaryTextBlock" Text="Run a scan to collect read-only system information." Margin="0,10,0,0" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                  <TextBlock Text="Report Export Scaffolding" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                  <TextBlock Text="Version 1 exports a branded Markdown report draft. PDF export is intentionally left for the dedicated PDF task." Margin="0,10,0,0" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Fixed-Drive Storage" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <DataGrid x:Name="FixedDrivesDataGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Margin="0,12,0,0"
                          MinHeight="120">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Drive" Binding="{Binding Name}" Width="120" />
                    <DataGridTextColumn Header="Format" Binding="{Binding Format}" Width="120" />
                    <DataGridTextColumn Header="Capacity" Binding="{Binding Capacity}" Width="160" />
                    <DataGridTextColumn Header="Free Space" Binding="{Binding FreeSpace}" Width="160" />
                    <DataGridTextColumn Header="Free %" Binding="{Binding FreePercent}" Width="*" />
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Findings" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <DataGrid x:Name="FindingsDataGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Margin="0,12,0,0"
                          MinHeight="220">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150" />
                    <DataGridTextColumn Header="Finding" Binding="{Binding Name}" Width="220" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" />
                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16">
              <StackPanel>
                <TextBlock Text="Technician Notes" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <TextBox x:Name="TechnicianNotesTextBox" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Grid>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1,1,0,0" Padding="16,10">
      <TextBlock Text="SignalScan provides a technician-reviewed system health assessment based on available diagnostic information at the time of scan. Findings are intended to guide maintenance and support decisions." Foreground="#5D6B7F" TextWrapping="Wrap" />
    </Border>
  </Grid>
</Window>
