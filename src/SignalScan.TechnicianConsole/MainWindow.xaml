<Window x:Class="SignalScan.TechnicianConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SignalScan Technician Console"
        Height="820"
        Width="1180"
        MinHeight="720"
        MinWidth="980"
        Background="#F3F6FA">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource SignalNavy}" Padding="24,18">
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="SignalScan" Foreground="White" FontSize="30" FontWeight="Bold" />
          <TextBlock Text="by 909 Signal IT - Technician Console" Foreground="#BFD7FF" FontSize="14" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
          <TextBlock Text="Read-only diagnostic mode" Foreground="#A9F59B" FontWeight="SemiBold" TextAlignment="Right" />
          <TextBlock Text="No repair, cleanup, deletion, or configuration changes" Foreground="White" FontSize="12" TextAlignment="Right" />
        </StackPanel>
      </DockPanel>
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="24">
        <Border Background="#EAF7EA" BorderBrush="#BDE8B6" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,16">
          <TextBlock TextWrapping="Wrap">
            <Run FontWeight="Bold" Text="Safety rule: " />
            <Run Text="SignalScan v1 only inspects and reports. It does not delete files, modify registry keys, disable services, change drivers, remove malware, alter firewall/Defender settings, or perform automatic repairs." />
          </TextBlock>
        </Border>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Client and Device" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <TextBlock Text="Client name" Margin="0,12,0,0" />
                <TextBox x:Name="ClientNameTextBox" />
                <TextBlock Text="Client phone or email" />
                <TextBox x:Name="ClientContactTextBox" />
                <TextBlock Text="Device label" />
                <TextBox x:Name="DeviceLabelTextBox" />
                <TextBlock Text="Recommended service package" />
                <ComboBox x:Name="RecommendedServiceComboBox">
                  <ComboBoxItem Content="SignalScan PC Health Check" IsSelected="True" />
                  <ComboBoxItem Content="SignalScan Tune-Up" />
                  <ComboBoxItem Content="SignalScan Security Review" />
                  <ComboBoxItem Content="SignalScan Business Workstation Assessment" />
                  <ComboBoxItem Content="SignalCare Monthly Maintenance Plan" />
                </ComboBox>
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16">
              <StackPanel>
                <TextBlock Text="Actions" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <TextBlock Text="All actions are read-only or report export only. Technician summary and recommendation text must be reviewed before export." Foreground="#5D6B7F" Margin="0,6,0,12" TextWrapping="Wrap" />
                <Button x:Name="RunScanButton" Content="Run Read-Only Scan" Background="{StaticResource SignalBlue}" Foreground="White" Click="RunScanButton_Click" Margin="0,0,0,10" />
                <Button x:Name="ExportPdfReportButton" Content="Export PDF Report" Click="ExportPdfReportButton_Click" Margin="0,0,0,10" IsEnabled="False" />
                <Button x:Name="ExportMarkdownDraftButton" Content="Export Markdown Draft" Click="ExportMarkdownDraftButton_Click" Margin="0,0,0,10" IsEnabled="False" />
                <TextBlock x:Name="StatusMessageTextBlock" Text="Ready to scan." Foreground="#5D6B7F" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Grid.Column="2">
            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,16">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="Technician Dashboard" FontSize="22" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                  <TextBlock x:Name="ScanTimestampTextBlock" Text="No scan has been run yet." Foreground="#5D6B7F" Margin="0,6,0,0" />
                </StackPanel>
                <Border Grid.Column="1" Background="#F8FBFF" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="12">
                  <StackPanel>
                    <TextBlock Text="Overall Status" Foreground="#5D6B7F" />
                    <TextBlock x:Name="OverallStatusTextBlock" Text="Review Required" FontSize="22" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                  </StackPanel>
                </Border>
              </Grid>
            </Border>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                  <TextBlock Text="System Summary" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                  <TextBlock x:Name="SystemSummaryTextBlock" Text="Run a scan to collect read-only system information." Margin="0,10,0,0" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                  <TextBlock Text="Report Export" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                  <TextBlock Text="Export a branded client-facing PDF report or a Markdown draft/debug report from the current read-only scan." Margin="0,10,0,0" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Performance Snapshot" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <UniformGrid Columns="3" Margin="0,12,0,0">
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="CPU Usage" Foreground="#5D6B7F" />
                    <TextBlock x:Name="CpuUsageTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="RAM Usage" Foreground="#5D6B7F" />
                    <TextBlock x:Name="RamUsageTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="RAM Available" Foreground="#5D6B7F" />
                    <TextBlock x:Name="RamAvailableTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Startup Entries" Foreground="#5D6B7F" />
                    <TextBlock x:Name="StartupAppCountTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Processes" Foreground="#5D6B7F" />
                    <TextBlock x:Name="ProcessCountTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Uptime" Foreground="#5D6B7F" />
                    <TextBlock x:Name="UptimeIndicatorTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                </UniformGrid>
                <TextBlock x:Name="DiskFreeEvaluationTextBlock" Text="Disk free evaluation unavailable." Foreground="#5D6B7F" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Fixed-Drive Storage" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <DataGrid x:Name="FixedDrivesDataGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Margin="0,12,0,0"
                          MinHeight="120">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Drive" Binding="{Binding Name}" Width="120" />
                    <DataGridTextColumn Header="Format" Binding="{Binding Format}" Width="120" />
                    <DataGridTextColumn Header="Capacity" Binding="{Binding Capacity}" Width="160" />
                    <DataGridTextColumn Header="Free Space" Binding="{Binding FreeSpace}" Width="160" />
                    <DataGridTextColumn Header="Free %" Binding="{Binding FreePercent}" Width="*" />
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Maintenance Snapshot" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <UniformGrid Columns="3" Margin="0,12,0,0">
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Pending Reboot" Foreground="#5D6B7F" />
                    <TextBlock x:Name="PendingRebootTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Update Status" Foreground="#5D6B7F" />
                    <TextBlock x:Name="WindowsUpdateStatusTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Update Status Date" Foreground="#5D6B7F" />
                    <TextBlock x:Name="WindowsUpdateStatusDateTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Last Successful Install" Foreground="#5D6B7F" />
                    <TextBlock x:Name="LastSuccessfulUpdateTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Event Logs" Foreground="#5D6B7F" />
                    <TextBlock x:Name="EventLogSummaryTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Disk Health" Foreground="#5D6B7F" />
                    <TextBlock x:Name="DiskHealthStatusTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                </UniformGrid>
                <TextBlock Text="Maintenance checks are read-only. SignalScan does not install updates, repair disks, clear logs, delete files, or change settings." Foreground="#5D6B7F" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Security Snapshot" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <UniformGrid Columns="3" Margin="0,12,0,0">
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Defender" Foreground="#5D6B7F" />
                    <TextBlock x:Name="DefenderStatusTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Firewall Profiles" Foreground="#5D6B7F" />
                    <TextBlock x:Name="FirewallProfileStatusTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="BitLocker" Foreground="#5D6B7F" />
                    <TextBlock x:Name="BitLockerStatusTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Local Admins" Foreground="#5D6B7F" />
                    <TextBlock x:Name="LocalAdministratorCountTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,12">
                    <TextBlock Text="Windows Support" Foreground="#5D6B7F" />
                    <TextBlock x:Name="WindowsSupportStatusTextBlock" Text="Unavailable" FontSize="18" FontWeight="Bold" />
                  </StackPanel>
                </UniformGrid>
                <TextBlock Text="Security checks are read-only. SignalScan does not change Defender, firewall, BitLocker, user accounts, group policy, services, or registry settings." Foreground="#5D6B7F" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Local Scan History" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <TextBlock x:Name="HistoryStorePathTextBlock" Text="Local history store unavailable." Foreground="#5D6B7F" Margin="0,6,0,0" TextWrapping="Wrap" />
                <TextBlock Text="History is stored only on this Windows profile and contains minimal scan/report metadata." Foreground="#5D6B7F" Margin="0,4,0,0" TextWrapping="Wrap" />
                <DataGrid x:Name="ScanHistoryDataGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Margin="0,12,0,0"
                          MinHeight="150">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Scan Date" Binding="{Binding ScanTimestamp}" Width="140" />
                    <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="140" />
                    <DataGridTextColumn Header="Device" Binding="{Binding DeviceName}" Width="140" />
                    <DataGridTextColumn Header="Status" Binding="{Binding OverallStatus}" Width="130" />
                    <DataGridTextColumn Header="Service" Binding="{Binding RecommendedService}" Width="180" />
                    <DataGridTextColumn Header="PDF Path" Binding="{Binding ExportedPdfPath}" Width="220" />
                    <DataGridTextColumn Header="Markdown Path" Binding="{Binding ExportedMarkdownPath}" Width="220" />
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Performance Findings" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <DataGrid x:Name="PerformanceFindingsDataGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Margin="0,12,0,0"
                          MinHeight="170">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Finding" Binding="{Binding Name}" Width="220" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" />
                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Maintenance Findings" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <DataGrid x:Name="MaintenanceFindingsDataGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Margin="0,12,0,0"
                          MinHeight="170">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Finding" Binding="{Binding Name}" Width="220" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" />
                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Security Findings" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <DataGrid x:Name="SecurityFindingsDataGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Margin="0,12,0,0"
                          MinHeight="170">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Finding" Binding="{Binding Name}" Width="220" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" />
                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="All Findings Summary" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <TextBlock Text="Combined read-only findings across System Profile, Performance, Maintenance, and Security." Foreground="#5D6B7F" Margin="0,6,0,0" TextWrapping="Wrap" />
                <DataGrid x:Name="FindingsDataGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Margin="0,12,0,0"
                          MinHeight="220">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150" />
                    <DataGridTextColumn Header="Finding" Binding="{Binding Name}" Width="220" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" />
                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Technician Review and Recommendations" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <TextBlock Text="Offline AI draft text is generated locally from the current scan. The technician decides what to keep and must review all text before export." Foreground="#5D6B7F" Margin="0,6,0,10" TextWrapping="Wrap" />
                <Button x:Name="GenerateOfflineSummaryButton" Content="Generate Offline Draft Summary" Click="GenerateOfflineSummaryButton_Click" IsEnabled="False" Margin="0,0,0,10" />
                <TextBlock Text="Technician-reviewed summary" />
                <TextBox x:Name="TechnicianReviewedSummaryTextBox" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                <TextBlock Text="Next-step recommendation" Margin="0,10,0,0" />
                <TextBox x:Name="NextStepRecommendationTextBox" AcceptsReturn="True" MinHeight="80" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
              </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="16">
              <StackPanel>
                <TextBlock Text="Technician Notes" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SignalNavy}" />
                <TextBox x:Name="TechnicianNotesTextBox" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Grid>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1,1,0,0" Padding="16,10">
      <TextBlock Text="SignalScan provides a technician-reviewed system health assessment based on available diagnostic information at the time of scan. Findings are intended to guide maintenance and support decisions." Foreground="#5D6B7F" TextWrapping="Wrap" />
    </Border>
  </Grid>
</Window>
